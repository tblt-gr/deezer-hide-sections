{
  "manifest_version": 3,
  "name": "Deezer Hide Sections",
  "version": "1.0.0",
  "description": "Hide unwanted sections on Deezer pages.",
  "browser_specific_settings": {
    "gecko": {
      "id": "deezer-hide-sections@tblt-gr",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Deezer Hide Sections",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "web_accessible_resources": [
    {
      "resources": ["icons/hide-button.svg"],
      "matches": ["https://www.deezer.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://www.deezer.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
